---
import Layout from "./main.astro";
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <main
    class="relative z-30 max-w-4xl pb-1 mx-auto mt-10 bg-white dark:bg-neutral-950 md:rounded-t-md text-neutral-900"
  >
    <div
      class="relative flex flex-col px-5 pt-6 border-t border-b-0 md:border-r md:border-l md:pt-20 lg:px-0 justify-stretch md:rounded-t-2xl border-neutral-200 dark:border-neutral-800"
    >
      <div
        class="absolute top-0 left-0 hidden w-px h-full mt-1 -translate-x-px md:block bg-gradient-to-b from-transparent to-white dark:to-neutral-950"
      >
      </div>
      <div
        class="absolute top-0 right-0 hidden w-px h-full mt-1 translate-x-px md:block bg-gradient-to-b from-transparent to-white dark:to-neutral-950"
      >
      </div>
      <div class="w-full max-w-2xl mx-auto">
        <h1
          class="text-3xl font-bold leading-tight tracking-tighter text-left mb-4 md:mb-6 md:text-4xl dark:text-neutral-100 lg:text-5xl md:leading-none"
        >
          {frontmatter.title}
        </h1>
        <div class="mb-6 md:mb-7">
          <div class="inline-flex items-center gap-3 rounded-full border border-neutral-200 bg-white/90 px-3 py-2 text-sm text-neutral-700 shadow-sm dark:border-neutral-800 dark:bg-neutral-900/90 dark:text-neutral-200">
            <button
              id="listen-article-button"
              type="button"
              class="flex h-10 w-10 items-center justify-center rounded-full bg-neutral-100 text-neutral-900 transition hover:bg-neutral-200 dark:bg-neutral-800 dark:text-neutral-100 dark:hover:bg-neutral-700"
              aria-label="听全文"
            >
              <svg
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-4 w-4"
              >
                <path d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 0 0 0-1.68L9.54 5.98A1 1 0 0 0 8 6.82Z"></path>
              </svg>
            </button>
            <div class="min-w-0">
              <button
                id="listen-article-toggle"
                type="button"
                class="block text-left font-medium leading-none text-neutral-900 transition hover:text-neutral-600 dark:text-neutral-100 dark:hover:text-neutral-300"
              >
                <span id="listen-article-label">听全文</span>
              </button>
              <p id="listen-article-status" class="mt-1 text-xs text-neutral-500 dark:text-neutral-400">
                AI 语音朗读正文
              </p>
            </div>
          </div>
        </div>
        <time
          class="block text-sm text-neutral-500 dark:text-neutral-400 mb-12 md:mb-16"
        >
          {frontmatter.dateFormatted}
        </time>
      </div>
    </div>

    <article
      id="article-content"
      class="w-full max-w-2xl mx-auto mb-12 prose-base prose px-5 lg:px-0 lg:prose-lg dark:prose-invert"
    >
      <slot />
    </article>

    <div class="w-full max-w-2xl mx-auto px-5 lg:px-0 mb-16">
      <slot name="nav" />
    </div>
  </main>

  <script is:inline>
    const listenButton = document.getElementById('listen-article-button');
    const listenToggle = document.getElementById('listen-article-toggle');
    const listenLabel = document.getElementById('listen-article-label');
    const listenStatus = document.getElementById('listen-article-status');
    const articleContent = document.getElementById('article-content');

    const TTS_API = 'https://tts.134688.xyz';
    const TTS_TOKEN = 'tts100412';

    if (listenButton && listenToggle && listenLabel && listenStatus && articleContent) {
      let audio;
      let isSpeaking = false;
      let activeRead = false;
      let abortController;

      const playIcon = `
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
          <path d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 0 0 0-1.68L9.54 5.98A1 1 0 0 0 8 6.82Z"></path>
        </svg>`;
      const stopIcon = `
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
          <rect x="7" y="7" width="10" height="10" rx="2"></rect>
        </svg>`;
      const spinnerIcon = `
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-4 w-4 animate-spin">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"></circle>
          <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
        </svg>`;

      const updateState = ({ label, status, icon, pressed }) => {
        listenLabel.textContent = label;
        listenStatus.textContent = status;
        listenButton.setAttribute('aria-label', label);
        listenButton.setAttribute('aria-pressed', String(pressed));
        listenToggle.setAttribute('aria-label', label);
        listenButton.innerHTML = icon;
      };

      function splitText(text, maxLen) {
        const parts = [];
        while (text.length > maxLen) {
          let cut = maxLen;
          const chunk = text.slice(0, maxLen);
          const lastPeriod = Math.max(chunk.lastIndexOf('。'), chunk.lastIndexOf('！'), chunk.lastIndexOf('？'), chunk.lastIndexOf('\n'));
          if (lastPeriod > maxLen * 0.4) cut = lastPeriod + 1;
          parts.push(text.slice(0, cut).trim());
          text = text.slice(cut).trim();
        }
        if (text.trim()) parts.push(text.trim());
        return parts;
      }

      async function fetchAudio(text) {
        const params = new URLSearchParams({ text, voiceName: 'zh-CN-XiaoxiaoNeural', token: TTS_TOKEN });
        const response = await fetch(`${TTS_API}/api/synthesis?${params}`, { signal: abortController.signal });
        if (!response.ok) throw new Error('TTS API error');
        return response.blob();
      }

      const stopReading = () => {
        activeRead = false;
        abortController?.abort();
        if (audio) {
          audio.pause();
          audio.src = '';
          audio = null;
        }
        isSpeaking = false;
        updateState({ label: '听全文', status: 'AI 语音朗读正文', icon: playIcon, pressed: false });
      };

      const startReading = async () => {
        const fullText = articleContent.innerText.replace(/\s+/g, ' ').trim();
        if (!fullText) return;

        activeRead = true;
        abortController = new AbortController();
        const chunks = splitText(fullText, 300);

        updateState({ label: '加载中', status: `正在合成第 1/${chunks.length} 段`, icon: spinnerIcon, pressed: true });

        try {
          const firstBlob = await fetchAudio(chunks[0]);
          const playNext = async (index) => {
            if (!activeRead) return;
            if (index >= chunks.length) {
              isSpeaking = false;
              audio = null;
              updateState({ label: '听全文', status: 'AI 语音朗读正文', icon: playIcon, pressed: false });
              return;
            }

            let blob;
            if (index === 0) {
              blob = firstBlob;
            } else {
              updateState({ label: '停止朗读', status: `正在合成第 ${index + 1}/${chunks.length} 段`, icon: spinnerIcon, pressed: true });
              try {
                blob = await fetchAudio(chunks[index]);
              } catch {
                if (!activeRead) return;
                throw new Error('fetch failed');
              }
            }

            if (!activeRead) return;
            const url = URL.createObjectURL(blob);
            audio = new Audio(url);
            audio.onplay = () => {
              isSpeaking = true;
              updateState({ label: '停止朗读', status: `正在朗读第 ${index + 1}/${chunks.length} 段`, icon: stopIcon, pressed: true });
            };
            audio.onended = () => { URL.revokeObjectURL(url); playNext(index + 1); };
            audio.onerror = () => { URL.revokeObjectURL(url); playNext(index + 1); };
            audio.play();
          };

          playNext(0);
        } catch {
          if (!abortController.signal.aborted) {
            isSpeaking = false;
            updateState({ label: '听全文', status: '语音合成失败，请稍后重试', icon: playIcon, pressed: false });
          }
        }
      };

      const handleToggle = () => {
        if (isSpeaking) { stopReading(); return; }
        startReading();
      };

      listenButton.addEventListener('click', handleToggle);
      listenToggle.addEventListener('click', handleToggle);
      window.addEventListener('beforeunload', stopReading);
    } else if (listenButton?.parentElement?.parentElement) {
      listenButton.parentElement.parentElement.hidden = true;
    }
  </script>
</Layout>
