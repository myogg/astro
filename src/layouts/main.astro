---
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import SquareLines from "../components/square-lines.astro";
const { title, description = "北方的博客 — 生活感悟与技术探索" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 北方的博客</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | 北方的博客`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="北方的博客" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | 北方的博客`} />
    <meta name="twitter:description" content={description} />

    <!-- Used to add dark mode right away, adding here prevents any flicker -->
    <script is:inline>
      if (typeof Storage !== 'undefined') {
        if (
          localStorage.getItem('dark_mode') &&
          localStorage.getItem('dark_mode') == 'true'
        ) {
          document.documentElement.classList.add('dark')
        }
      }
    </script>

    <style>
      .prose img {
        border-radius: 20px;
      }

      /* 中文字体 + 衬线正文 */
      .prose {
        font-family: "LXGW WenKai", "Noto Serif SC", "Source Han Serif SC", "STSong", Georgia, "Times New Roman", serif;
        hanging-punctuation: first allow-end last;
        max-width: 65ch;
      }

      .prose h1,
      .prose h2,
      .prose h3,
      .prose h4,
      .prose h5,
      .prose h6 {
        font-family: "Noto Sans SC", "Source Han Sans SC", "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
      }

      .prose h1 { line-height: 1.15; }
      .prose h2 { line-height: 1.3; margin-top: 2em; }
      .prose h3 { line-height: 1.5; margin-top: 1.6em; }

      /* 首字下沉 — 首字母用衬线体，中文首字也生效 */
      .prose > p:first-of-type::first-letter {
        float: left;
        font-size: 3.5em;
        line-height: 0.85;
        padding-right: 0.08em;
        margin-top: 0.02em;
        font-weight: 700;
        font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        color: inherit;
      }

      .prose > p:first-of-type {
        clear: both;
      }

      /* 中文段落间距优化 */
      .prose p {
        margin-bottom: 1.5em;
        line-height: 1.85;
      }

      /* 引用块样式 */
      .prose blockquote {
        border-left-color: #a1a1aa;
        font-style: normal;
      }

    </style>
    <link rel="icon" type="image/x-icon" href="../assets/images/favicon.png" />
    <!-- 中文字体 CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-mono-webfont@1.7.0/style.css" />
    <script src="../assets/css/main.css"></script>
    <Fragment set:html={import.meta.env.HEADER_INJECT} />
  </head>
  <body class="antialiased bg-white dark:bg-neutral-950">
    <SquareLines />
    <Header />
    <slot />
    <Footer />
    <script src="../assets/js/main.js"></script>
    <!-- 外链处理：新窗口 + nofollow -->
    <script is:inline>
      document.querySelectorAll('.prose a[href^="http"]').forEach(a => {
        if (!a.target) a.target = '_blank';
        a.rel = 'nofollow noopener noreferrer';
      });
    </script>
    <Fragment set:html={import.meta.env.FOOTER_INJECT} />
  </body>
</html>
