---
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import SquareLines from "../components/square-lines.astro";
const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Used to add dark mode right away, adding here prevents any flicker -->
    <script is:inline>
      if (typeof Storage !== 'undefined') {
        if (
          localStorage.getItem('dark_mode') &&
          localStorage.getItem('dark_mode') == 'true'
        ) {
          document.documentElement.classList.add('dark')
        }
      }
    </script>

    <style>
      .prose img {
        border-radius: 20px;
      }

      /* 中文字体 + 衬线正文 */
      .prose {
        font-family: "LXGW WenKai", "Noto Serif SC", "Source Han Serif SC", "STSong", Georgia, "Times New Roman", serif;
        hanging-punctuation: first allow-end last;
      }

      .prose h1,
      .prose h2,
      .prose h3,
      .prose h4,
      .prose h5,
      .prose h6 {
        font-family: "Noto Sans SC", "Source Han Sans SC", "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
      }

      /* 首字下沉 */
      .prose > p:first-of-type::first-letter {
        float: left;
        font-size: 3.5em;
        line-height: 0.8;
        padding-right: 0.1em;
        margin-top: 0.05em;
        font-weight: 700;
        color: inherit;
      }

      /* 中文段落间距优化 */
      .prose p {
        margin-bottom: 1.5em;
        line-height: 1.85;
      }

      /* 引用块样式 */
      .prose blockquote {
        border-left-color: #a1a1aa;
        font-style: normal;
      }

    </style>
    <link rel="icon" type="image/x-icon" href="../assets/images/favicon.png" />
    <!-- 中文字体 CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-mono-webfont@1.7.0/style.css" />
    <script src="../assets/css/main.css"></script>
    <Fragment set:html={import.meta.env.HEADER_INJECT} />
  </head>
  <body class="antialiased bg-white dark:bg-neutral-950">
    <SquareLines />
    <Header />
    <slot />
    <Footer />
    <script src="../assets/js/main.js"></script>
    <!-- 外链处理：新窗口 + nofollow -->
    <script is:inline>
      document.querySelectorAll('.prose a[href^="http"]').forEach(a => {
        if (!a.target) a.target = '_blank';
        a.rel = 'nofollow noopener noreferrer';
      });
    </script>
    <Fragment set:html={import.meta.env.FOOTER_INJECT} />
  </body>
</html>
