---
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="首页">
  <div class="relative z-20 w-full max-w-screen-md mx-auto mt-16 px-7 md:mt-24 lg:mt-32">
    <div class="flex flex-col items-start">
      <div class="w-full">
        <h1 class="mb-8 text-4xl font-medium leading-tight tracking-tight text-black dark:text-white md:text-5xl">
          Hello, I'm Jss.
        </h1>
        
        <div class="space-y-5 text-base md:text-lg text-neutral-500 dark:text-neutral-400 leading-relaxed">
          <p>
            I'm an ordinary person living in Xi'an, exploring the intersection of life and technology.
          </p>
          <p>
            Xi'an is an ancient city rich in historical heritage, providing a unique backdrop for modern tinkering.
          </p>
          <p>
            I spend my time building blogs, forums, and mobile applications—focusing on simplicity and function.
          </p>
          <p>
            I'll be here to share thoughts on life, or any other topics that spark curiosity.
          </p>
        </div>
      </div>

      <div class="relative w-full mt-12 overflow-hidden rounded-xl bg-neutral-50 dark:bg-neutral-900">
        <img
          src="/assets/images/photo.webp"
          loading="eager"
          decoding="auto"
          class="w-full h-auto object-cover grayscale hover:grayscale-0 transition-all duration-700"
        />
      </div>
    </div>
  </div>

  <div class="mt-24">
    <Separator text="Projects" />
    <Projects />
  </div>

  <div class="mt-16 mb-24">
    <Separator text="Writing" />
    <Writings />
  </div>
</Layout>
