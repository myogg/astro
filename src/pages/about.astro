---
import categories from "../collections/links.json";
import AboutLink from "../components/about-link.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="About Me">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="About Me"
      description="Hello 👋 I'm an ordinary person living in Xi'an. I love tinkering with things—blogs, forums, and all kinds of mobile apps."
    />

    <img src="/assets/images/about.jpg" class="relative z-30 w-full my-10 rounded-xl" />

    <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">Short Bio</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      I'm an ordinary person living in Xi'an, and I don't really know how to do anything special. I love tinkering with things—blogs, forums, and all kinds of mobile apps... I'll be here to chat about life, or any other topics that interest me.
    </p>

    <div class="nav-page">
      <div class="nav-page-title">
        <h2 class="text-2xl font-bold dark:text-neutral-200">我的导航</h2>
        <p class="text-sm text-gray-400">常用网址收藏</p>
      </div>

      {categories.map((cat) => (
        <div class="nav-category">
          <div class="nav-category-title">{cat.title}</div>
          <div class="nav-grid">
            {cat.links.map((link) => (
              <AboutLink
                url={link.url}
                name={link.name}
                desc={link.desc}
              />
            ))}
          </div>
        </div>
      ))}
    </div>

    <h2 class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200">Let's Connect</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      If you want to stay up to date with my work be sure to <a
        href="https://x.com/JLengYu"
        target="_blank"
        class="text-indigo-600 underline">follow me on twitter</a
      >, or you can send me an <a href="mailto:xxjss@hotmail.com" class="text-indigo-600 underline"
        >email</a
      > and I'll be sure to get back to you.
    </p>
  </section>
</Layout>

<style>
  .nav-page {
    margin-top: 2rem;
  }
  .nav-page-title {
    text-align: center;
    margin-bottom: 40px;
  }
  .nav-page-title h2 {
    margin-bottom: 8px;
  }
  .nav-category {
    margin-bottom: 36px;
  }
  .nav-category-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
    padding-left: 12px;
    border-left: 3px solid #3498db;
    color: #333;
  }
  :global(.dark) .nav-category-title {
    color: #d4d4d4;
  }
  .nav-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 900px) {
    .nav-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 600px) {
    .nav-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
