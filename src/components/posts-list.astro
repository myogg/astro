---
const { posts } = Astro.props;
---

<div class="flex flex-col border-t border-black/5 dark:border-white/10 mt-8">
  {
    posts.map((post) => (
      <a 
        href={`/post/${post.slug}/`} 
        class="group block py-8 border-b border-black/5 dark:border-white/10 transition-opacity hover:opacity-60"
      >
        <article class="flex flex-col gap-1.5">
          <div class="text-[10px] tracking-[0.2em] uppercase text-neutral-400 font-medium mb-1">
            {post.data.dateFormatted}
          </div>
          <h2 class="text-black dark:text-white">{post.data.title}</h2>
          {post.data.description && (
            <p class="text-sm text-neutral-500 line-clamp-2 max-w-2xl">
              {post.data.description}
            </p>
          )}
        </article>
      </a>
    ))
  }
</div>
