---
import type { CollectionEntry } from "astro:content";

const { posts } = Astro.props as { posts: CollectionEntry<"post">[] };
---

<div class="z-50 flex flex-col items-stretch w-full gap-5 my-8">
  {posts.map((post) => {
    const link = `/post/${post.slug}`;
    const postTags: string[] = post.data.tags || [];
    return (
      <div class="relative border border-transparent border-dashed p-7 group rounded-2xl">
        <a href={link} aria-label={post.data.title} class="absolute inset-0 z-20 rounded-2xl"></a>
        <div class="absolute inset-0 z-10 w-full h-full duration-300 ease-out bg-white border border-dashed dark:bg-neutral-950 rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:-translate-x-1 group-hover:-translate-y-1" />
        <div class="absolute inset-0 z-0 w-full h-full duration-300 ease-out border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:translate-x-1 group-hover:translate-y-1" />
        <div class="relative z-30 duration-300 ease-out group-hover:-translate-x-1 group-hover:-translate-y-1">
          <h2 class="flex items-center mb-3">
            <a
              href={link}
              class="text-base font-bold leading-tight tracking-tight sm:text-lg dark:text-neutral-100"
            >
              {post.data.title}
            </a>
          </h2>
          <p class="text-sm text-neutral-600 dark:text-neutral-400">
            <span>{post.data.description}</span>
          </p>
          <div class="flex items-center justify-between mt-2.5">
            <div class="text-xs font-medium text-neutral-800 dark:text-neutral-300">
              {post.data.dateFormatted}
            </div>
            {postTags.length > 0 && (
              <div class="flex gap-1.5">
                {postTags.map((tagName: string) => (
                  <a
                    href={`/tags/${tagName}`}
                    class="relative z-40 text-xs px-2 py-0.5 border border-dashed border-neutral-300 dark:border-neutral-700 rounded-full text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors"
                  >
                    {tagName}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    );
  })}
</div>
